{
  "name": "daksh-inventory",
  "version": "1.0.0",
  "description": "Inventory Audit System - Real-time inventory tracking and management",
  "main": "server.js",
  "type": "module",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "jest --coverage",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage --collectCoverageFrom='src/**/*.js'",
    "lint": "eslint src/**/*.js",
    "lint:fix": "eslint src/**/*.js --fix",
    "format": "prettier --write 'src/**/*.js'",
    "build": "echo 'No build step needed for Node.js'",
    "seed": "node scripts/seed.js"
  },
  "keywords": [
    "inventory",
    "audit",
    "management",
    "tracking",
    "warehouse"
  ],
  "author": "amitsvision4u-glitch",
  "license": "MIT",
  "dependencies": {
    "express": "^4.18.2",
    "mongoose": "^7.5.0",
    "dotenv": "^16.3.1",
    "cors": "^2.8.5",
    "helmet": "^7.0.0",
    "morgan": "^1.10.0",
    "express-validator": "^7.0.0",
    "bcryptjs": "^2.4.3",
    "jsonwebtoken": "^9.1.0",
    "redis": "^4.6.10",
    "winston": "^3.10.0",
    "compression": "^1.7.4",
    "express-rate-limit": "^7.0.0"
  },
  "devDependencies": {
    "nodemon": "^3.0.1",
    "jest": "^29.7.0",
    "supertest": "^6.3.3",
    "eslint": "^8.49.0",
    "prettier": "^3.0.3",
    "@faker-js/faker": "^8.2.0"
  },
  "engines": {
    "node": ">=16.0.0",
    "npm": ">=8.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/amitsvision4u-glitch/daksh-inventory.git"
  },
  "bugs": {
    "url": "https://github.com/amitsvision4u-glitch/daksh-inventory/issues"
  },
  "homepage": "https://github.com/amitsvision4u-glitch/daksh-inventory#readme"
}
